{
  "rules": {
    // Matches - anyone can read, only admins can write
    "matches": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('admin').val() === true"
    },

    // Users - anyone can read, users can write their own profile, admins can write any
    "users": {
      ".read": true,
      "$userId": {
        ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('admin').val() === true)",
        // Prevent non-admins from setting admin flag
        "admin": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('admin').val() === true"
        }
      }
    },

    // Usernames index - anyone can read, special write rules
    "usernames": {
      ".read": true,
      "$normalizedUsername": {
        // Can write if: claiming for yourself OR releasing your own OR admin
        ".write": "auth != null && (newData.val() === auth.uid || !data.exists() || data.val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)"
      }
    },

    // Predictions - anyone can read, users can only write their own (admins can write any)
    "predictions": {
      "$userId": {
        // Anyone can read predictions (to view other users' predictions)
        ".read": true,
        // Users can delete their own predictions (for account deletion), admins can write/delete all
        ".write": "auth != null && ((auth.uid === $userId && !newData.exists()) || root.child('users').child(auth.uid).child('admin').val() === true)",
        "$gameId": {
          // Users can write their own predictions before the configured deadline
          // Admins can write any predictions (for mock data)
          // Match timestamp is in seconds, now is in milliseconds
          ".write": "auth != null && ((auth.uid === $userId && now < root.child('matches').child($gameId).child('timestamp').val() * 1000 - root.child('settings').child('scoring').child('predictionDeadlineMinutes').val() * 60000) || root.child('users').child(auth.uid).child('admin').val() === true)",
          // Validate prediction structure
          ".validate": "newData.hasChildren(['homePrediction', 'awayPrediction', 'points', 'updatedAt'])",
          "homePrediction": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
          },
          "awayPrediction": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
          },
          "points": {
            // Users can only set points to 0, admins/functions can set any value
            ".validate": "newData.isNumber() && newData.val() >= 0 && (newData.val() === 0 || root.child('users').child(auth.uid).child('admin').val() === true)"
          },
          "updatedAt": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },

    // Leagues - anyone can read, owner can write
    "leagues": {
      ".read": true,
      "$leagueId": {
        // Only owner can update league settings
        ".write": "auth != null && (data.child('ownerId').val() === auth.uid || !data.exists())"
      }
    },

    // League slugs index - maps slug to leagueId
    "leagueSlugs": {
      ".read": true,
      "$slug": {
        ".write": "auth != null && (!data.exists() || root.child('leagues').child(data.val()).child('ownerId').val() === auth.uid)"
      }
    },

    // League members - who is in each league
    "leagueMembers": {
      ".read": true,
      "$leagueId": {
        // Allow owner or admin to delete the entire member list (for league deletion)
        ".write": "auth != null && (root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)",
        "$userId": {
          // Users can add/remove themselves, league owner can remove members, admin can remove anyone
          ".write": "auth != null && (auth.uid === $userId || root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)"
        }
      }
    },

    // User leagues - reverse index for quick lookup of user's leagues
    "userLeagues": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        // Users can delete their entire userLeagues entry (for account deletion)
        ".write": "auth != null && auth.uid === $userId && !newData.exists()",
        "$leagueId": {
          // Users can add/remove themselves, league owner can remove members, admin can remove anyone
          ".write": "auth != null && (auth.uid === $userId || root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)"
        }
      }
    },

    // App settings - public read, admin write only before tournament kickoff
    "settings": {
      ".read": true,
      "scoring": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('admin').val() === true && ((!data.exists() && now < newData.child('tournamentStartAt').val()) || (data.exists() && now < data.child('tournamentStartAt').val()))",
        ".validate": "newData.hasChildren(['exactScorePoints', 'correctResultPoints', 'scoreDifferencePenalty', 'minimumCorrectResultPoints', 'wrongResultPoints', 'formulaRules', 'predictionDeadlineMinutes', 'tournamentStartAt'])",
        "exactScorePoints": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
        },
        "correctResultPoints": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
        },
        "scoreDifferencePenalty": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
        },
        "minimumCorrectResultPoints": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
        },
        "wrongResultPoints": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
        },
        "bonusRules": {
          "$ruleId": {
            ".validate": "newData.hasChildren(['type', 'label', 'points', 'enabled'])",
            "type": {
              ".validate": "newData.isString() && (newData.val() === 'correctHomeScore' || newData.val() === 'correctAwayScore' || newData.val() === 'correctGoalDifference')"
            },
            "label": {
              ".validate": "newData.isString()"
            },
            "points": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
            },
            "enabled": {
              ".validate": "newData.isBoolean()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "formulaRules": {
          "$ruleId": {
            ".validate": "newData.hasChildren(['type', 'label', 'points', 'enabled'])",
            "type": {
              ".validate": "newData.isString() && (newData.val() === 'correctWinner' || newData.val() === 'correctGoalDifference' || newData.val() === 'exactScore' || newData.val() === 'correctDraw')"
            },
            "label": {
              ".validate": "newData.isString()"
            },
            "points": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
            },
            "enabled": {
              ".validate": "newData.isBoolean()"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "predictionDeadlineMinutes": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10080"
        },
        "tournamentStartAt": {
          ".validate": "newData.isNumber() && newData.val() > 0 && (!data.exists() || newData.val() === data.val())"
        },
        "updatedAt": {
          ".validate": "newData.isNumber()"
        },
        "updatedBy": {
          ".validate": "newData.isString()"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    // Default deny all other paths
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
